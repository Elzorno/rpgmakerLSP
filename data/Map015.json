{"id":7,"name":"Village Elder","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":6,"characterName":"People3","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["Kai. Come to check on an old man, have you?"]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["I heard the ground shake this morning."]},{"code":401,"indent":0,"parameters":["I've been waiting for that. Dreading it."]},{"code":401,"indent":0,"parameters":["For thirty years."]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["I know you've been looking at the hill."]},{"code":401,"indent":0,"parameters":["Don't deny it. I know that look."]},{"code":401,"indent":0,"parameters":["Your grandmother had it too."]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["I've told you: stay away from that hill."]},{"code":401,"indent":0,"parameters":["What I haven't told you is why."]},{"code":401,"indent":0,"parameters":["Not the whole truth. I'm telling you now."]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["That tremor wasn't natural."]},{"code":401,"indent":0,"parameters":["Something underground moved. Something"]},{"code":401,"indent":0,"parameters":["that has been asleep for a very long time."]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["The old world didn't end by accident."]},{"code":401,"indent":0,"parameters":["It was ended. On purpose. By one man."]},{"code":401,"indent":0,"parameters":["He lived in this village. His blood"]},{"code":401,"indent":0,"parameters":["still runs in these streets."]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["He sealed something in the cave beneath"]},{"code":401,"indent":0,"parameters":["that hill. He said it would wait there"]},{"code":401,"indent":0,"parameters":["until it was needed. That someone would"]},{"code":401,"indent":0,"parameters":["come to claim it. A descendant."]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["I always prayed that day would never come."]},{"code":401,"indent":0,"parameters":["That whatever is down there would stay"]},{"code":401,"indent":0,"parameters":["down there. That we could just... live."]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["But the ground shook this morning."]},{"code":401,"indent":0,"parameters":["And here you stand, looking at me with"]},{"code":401,"indent":0,"parameters":["those eyes. His eyes."]},{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2]},{"code":401,"indent":0,"parameters":["Be careful, Kai."]},{"code":401,"indent":0,"parameters":["Whatever is in that cave —"]},{"code":401,"indent":0,"parameters":["it was left there for a reason."]},{"code":401,"indent":0,"parameters":["So was the thing it's meant to stop."]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":6,"characterName":"People3","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["LSP_ElderFace",0,0,2,""]},{"code":401,"indent":0,"parameters":["Whatever you decide to do, Kai."]},{"code":401,"indent":0,"parameters":["I won't try to stop you anymore."]},{"code":401,"indent":0,"parameters":["Some things can't be outwaited."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":9,"y":5}
