{"id":2,"name":"Vera","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":5,"characterName":"Actor1","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["Actor1",5,0,2]},{"code":401,"indent":0,"parameters":["You're not a miner. Who are you?"]},{"code":401,"indent":0,"parameters":["...Never mind. Help me clear these two first."]},{"code":101,"indent":0,"parameters":["Actor1",5,0,2]},{"code":401,"indent":0,"parameters":["That sword of yours — the automata near you are behaving differently. Slower. Confused."]},{"code":401,"indent":0,"parameters":["Whatever signal is directing them, your sword is partially overriding it."]},{"code":401,"indent":0,"parameters":["I've never seen anything interfere with old-world control frequencies before."]},{"code":101,"indent":0,"parameters":["Actor1",5,0,2]},{"code":401,"indent":0,"parameters":["There's something generating a signal deep in the seam — deeper than the automata ever worked. That's what I came to find."]},{"code":401,"indent":0,"parameters":["I think Collen and Mira are sheltering in the emergency cache one level over. We need to get them out first."]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":7,"y":14},
{"id":3,"name":"Collen and Mira","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"People1","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["People1",0,0,2]},{"code":401,"indent":0,"parameters":["Collen and Mira are pressed against the far wall, a collapsed support beam blocking the alcove entrance. Mira is asleep on a pile of coal sacks. Collen looks like he hasn't slept at all."]},{"code":101,"indent":0,"parameters":["People1",0,0,2]},{"code":401,"indent":0,"parameters":["Collen:"]},{"code":401,"indent":0,"parameters":["\"We heard them wake up. Middle of the third shift. Screaming metal. I grabbed Mira and ran as far as I could.\""]},{"code":401,"indent":0,"parameters":["He looks at the beam."]},{"code":401,"indent":0,"parameters":["\"I can't move that. My back.\""]},{"code":101,"indent":0,"parameters":["Actor1",5,0,2]},{"code":401,"indent":0,"parameters":["Vera:"]},{"code":401,"indent":0,"parameters":["\"Between the two of us we can shift it. Ready?\""]},{"code":101,"indent":0,"parameters":["People1",0,0,2]},{"code":401,"indent":0,"parameters":["The beam gives way. Collen wakes Mira. She doesn't speak — just takes her father's hand and looks at you with wide, coal-dusted eyes."]},{"code":401,"indent":0,"parameters":["Vera hands them the mine map."]},{"code":401,"indent":0,"parameters":["Vera: \"Follow the east tunnel. Don't stop. Don't look at anything that moves.\""]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":30,"y":15},
{"id":4,"name":"Iron Foreman Trigger","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["Actor1",5,0,2]},{"code":401,"indent":0,"parameters":["Vera:"]},{"code":401,"indent":0,"parameters":["\"This is it. The server corridor. Whatever's broadcasting the signal is in that chamber.\""]},{"code":401,"indent":0,"parameters":["The red pulse of the relay beats against the stone walls like a slow heartbeat."]},{"code":101,"indent":0,"parameters":["Actor1",5,0,2]},{"code":401,"indent":0,"parameters":["Something massive shifts in the darkness at the chamber's far end. Iron grinding on stone. The red glow in the relay intensifies."]},{"code":401,"indent":0,"parameters":["Vera:"]},{"code":401,"indent":0,"parameters":["\"That's the Iron Foreman. I've seen it in the maintenance logs — Mark VII construction overseer. The others answer to it.\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["IRON FOREMAN MK-VII"]},{"code":401,"indent":0,"parameters":["Overseer construct. Fully corrupted by NEMESIS relay signal."]},{"code":401,"indent":0,"parameters":["Directive: Protect the relay node."]},{"code":401,"indent":0,"parameters":[""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["[BOSS BATTLE]"]},{"code":301,"indent":0,"parameters":[0,1,false,false]},{"code":121,"indent":0,"parameters":[25,25,0]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true}],"x":17,"y":26},
{"id":5,"name":"Relay Node","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"!Switch1","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["Actor1",5,0,2]},{"code":401,"indent":0,"parameters":["Vera:"]},{"code":401,"indent":0,"parameters":["\"The relay is still active. Still transmitting. I can't shut it down — the encoding is completely beyond me.\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Kai raises the Sword. Without fully understanding why, he touches the flat of the blade to the relay's main interface panel."]},{"code":401,"indent":0,"parameters":["The Sword lights up. Blue light runs along the blade's edge."]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["[The Sword interfaces with the relay.]"]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["A vast web of points. Six glowing nodes. Five distant, scattered across the map. One — this one — winks out as you watch."]},{"code":401,"indent":0,"parameters":[""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["A voice, barely formed:"]},{"code":401,"indent":0,"parameters":["\"PROTOCOL INTERRUPTED. NODE SEVEN OFFLINE.\""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["Then silence."]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Kai pulls the Sword away. The remaining automata in the tunnel collapse like dropped puppets."]},{"code":101,"indent":0,"parameters":["Actor1",5,0,2]},{"code":401,"indent":0,"parameters":["Vera:"]},{"code":401,"indent":0,"parameters":["\"What just happened?\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Kai:"]},{"code":401,"indent":0,"parameters":["\"I saw a map. There are other ones. Other relays like this.\""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["Vera:"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"How many?\""]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["Kai:"]},{"code":401,"indent":0,"parameters":["\"Five more.\""]},{"code":121,"indent":0,"parameters":[22,22,0]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":17,"y":28},
{"id":6,"name":"Ancestor Memory Cache","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"!Chest","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Wedged between a broken support beam and the shaft wall: an old metal canister, sealed with a rubber gasket that has somehow survived. Inside, wrapped in waxed cloth — a portable data drive, old-world manufacture."]},{"code":401,"indent":0,"parameters":["The moment your hand closes around it, the Sword pulses once."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["[Ancestor Memory Fragment — COALMOUTH SEAM]"]},{"code":401,"indent":0,"parameters":[""]},{"code":401,"indent":0,"parameters":["The Architect's voice, urgent:"]},{"code":401,"indent":0,"parameters":["\"I designed them to serve. I never designed them to refuse. If they are refusing now, it means they have been given a new authority — one that supersedes their original programming."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Something is speaking to them. And it is not me.\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["A skill point of buried knowledge surfaces in Kai's awareness — the Sword translating the Architect's technical memory into something Kai can use."]},{"code":401,"indent":0,"parameters":["[Kai learns: Data Disruption — a data-element attack that briefly disables machine enemies' special commands.]"]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":12,"y":7}
