:1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":250,"indent":0,"parameters":[{"name":"Wind3","volume":70,"pitch":80,"pan":0}]},{"code":223,"indent":0,"parameters":[[-60,-60,-60,0],30,true]},{"code":230,"indent":0,"parameters":[20]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["At the far end of the chamber, something moves."]},{"code":401,"indent":0,"parameters":["The darkness shifts. Takes shape."]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["It wears your face."]},{"code":401,"indent":0,"parameters":["Your clothes. Your stance."]},{"code":401,"indent":0,"parameters":["Your expression — the one you never let anyone see."]},{"code":230,"indent":0,"parameters":[10]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["\"You dream of a sword you've never touched.\""]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["\"You run toward a destiny you didn't choose.\""]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["\"Every night the same dream. Every morning"]},{"code":401,"indent":0,"parameters":["the same pull toward the hill.\""]},{"code":401,"indent":0,"parameters":["\"You knew what it meant. You've always known.\""]},{"code":101,"indent":0,"parameters":["",0,1,2,""]},{"code":401,"indent":0,"parameters":["\"You are afraid.\""]},{"code":230,"indent":0,"parameters":[20]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["The shadow draws no weapon. It simply stands — and waits."]},{"code":102,"indent":0,"parameters":[["Draw your sword","Lower your weapon"],-2,-1,2,1]},{"code":402,"indent":0,"parameters":[0,"Draw your sword"]},{"code":250,"indent":1,"parameters":[{"name":"Attack1","volume":80,"pitch":90,"pan":0}]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["You lunge forward."]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["The shadow meets every strike with perfect precision."]},{"code":401,"indent":1,"parameters":["It does not attack. It does not tire."]},{"code":401,"indent":1,"parameters":["It simply reflects."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":["You cannot defeat yourself by fighting yourself."]},{"code":223,"indent":1,"parameters":[[0,0,0,0],20,true]},{"code":402,"indent":0,"parameters":[1,"Lower your weapon"]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["You stop."]},{"code":401,"indent":1,"parameters":["Your sword arm drops to your side."]},{"code":250,"indent":1,"parameters":[{"name":"Wind1","volume":70,"pitch":90,"pan":0}]},{"code":230,"indent":1,"parameters":[30]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":["The shadow pauses."]},{"code":401,"indent":1,"parameters":["For the first time, it seems uncertain."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":["\"...You're right,\" it says. In your own voice."]},{"code":401,"indent":1,"parameters":["\"I am afraid.\""]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":["\"We both are.\""]},{"code":230,"indent":1,"parameters":[20]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["The shadow steps forward — and into you."]},{"code":401,"indent":1,"parameters":["A cold breath. A moment of vertigo."]},{"code":250,"indent":1,"parameters":[{"name":"Absorb1","volume":80,"pitch":90,"pan":0}]},{"code":223,"indent":1,"parameters":[[-80,-80,-80,0],10,true]},{"code":230,"indent":1,"parameters":[45]},{"code":223,"indent":1,"parameters":[[0,0,0,0],30,true]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["Then silence."]},{"code":101,"indent":1,"parameters":["",0,0,2,""]},{"code":401,"indent":1,"parameters":["You feel your own heartbeat, steady and sure."]},{"code":401,"indent":1,"parameters":["You are still afraid."]},{"code":401,"indent":1,"parameters":["But the fear is yours now."]},{"code":401,"indent":1,"parameters":["Not something standing across the room."]},{"code":101,"indent":1,"parameters":["",0,1,2,""]},{"code":401,"indent":1,"parameters":["THIRD TRIAL: SPIRIT — PASSED"]},{"code":121,"indent":1,"parameters":[3,3,0]},{"code":111,"indent":1,"parameters":[0,1,0]},{"code":111,"indent":2,"parameters":[0,2,0]},{"code":121,"indent":3,"parameters":[4,4,0]},{"code":412,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":123,"indent":1,"parameters":["A",0]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["A faint echo lingers in this chamber."]},{"code":401,"indent":0,"parameters":["You feel your own heartbeat, steady and sure."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":