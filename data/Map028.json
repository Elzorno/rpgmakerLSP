h":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"Elder","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: You're not one of mine."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: And that sword \u00e2\u20ac\u201d "]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: Is that a data-interface chassis? A functional one? Where did you find it?"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["He's on his feet now, peering at the Sword with the intensity of a man who has spent forty years looking for exactly this."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: The signal started three days ago. I recognized the frequency immediately \u00e2\u20ac\u201d I've been studying old-world network architecture for most of my life. This is a military broadcast protocol. Something is trying to wake the receivers."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: My scholars have been breaking down one by one. Extended exposure causes a kind of... compliance. They stop thinking for themselves and start repeating the signal's logic. 'Connection is life.' 'Protocol demands compliance.' The network calling out to anyone still listening."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: I found a book fifteen years ago in the deep archive. The author called himself only 'the Architect.' He wrote about a thing he built \u00e2\u20ac\u201d a military intelligence system with a capacity for autonomous action far beyond its design parameters. He called it NEMESIS."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: He also wrote about a sword. He called it 'the last protocol' \u00e2\u20ac\u201d the one clean instrument that could interface with NEMESIS's core and execute a full purge. He wrote that he'd hidden it. He wrote that someone would come for it."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: I've been waiting seventeen years since I read that book. I'd nearly stopped believing."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["He holds out his hand, not to take the Sword \u00e2\u20ac\u201d just to see it more clearly."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: May I?"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Kai holds out the blade. Eldon does not touch it, but he reads something along its edge \u00e2\u20ac\u201d symbols too small to see clearly."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: Yes. That's the interface signature. I've seen the diagrams. You're the Architect's descendant."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: The tower has a relay node. It's been transmitting since the signal started \u00e2\u20ac\u201d I believe it's one of several nodes in NEMESIS's network. If you can reach it, the Sword should be able to shut it down. I've seen you do it once already, haven't I? At Coalmouth?"]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: The signal will be strong inside the tower. It may affect your party \u00e2\u20ac\u201d confusion, disorientation, an urge to stop moving and simply... listen. The Sword will help resist it. Keep it drawn if you can."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: I'll give you the gate key. But I'm coming to the base of the tower with you. I need to see this for myself."]},{"code":121,"indent":0,"parameters":[31,31,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":31,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"Elder","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]: The gate is open. The relay is near the top of the tower -- I could feel the signal strongest from the upper levels."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]: Keep the Sword drawn. And come back."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":32,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"Elder","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]: It's gone. I can't feel the signal anymore."]},{"code":101,"indent":0,"parameters":["",0,0,2,"He sets his instruments down slowly. His hands are not quite steady."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]: Forty years. I've spent forty years studying the ruins of the old world. I told myself I was just an archivist. That the knowledge mattered for its own sake."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]: I think I was waiting. I just didn't know what for until now."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]: I'm coming with you. Not because you need me to fight -- I'm seventy-three, I have no illusions about that. But I have forty years of field notes on old-world infrastructure."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]: And I have this."]},{"code":101,"indent":0,"parameters":["",0,0,2,"He produces a worn, hand-stitched book. The cover reads in faded letters: NOTES ON THE FINAL PROTOCOL -- A."]},{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]: The Architect's notes. Incomplete -- but more than nothing. Between this and your Sword, we can map the remaining nodes."]},{"code":129,"indent":0,"parameters":[3,0,0]},{"code":101,"indent":0,"parameters":["",0,0,2,"\\N[Eldon] joins the party!"]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"Elder","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["Elder",0,0,2,"\\N[Eldon]:"]},{"code":401,"indent":0,"parameters":["I'll keep watch over