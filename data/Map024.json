{"id":2,"name":"Dunna","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":4,"characterName":"People2","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["People2",4,0,2]},{"code":401,"indent":0,"parameters":["Dunna sets a cracked mug down on the bar with the practiced thud of someone who has been setting things down on bars for forty years."]},{"code":401,"indent":0,"parameters":["\"Traveler. Stranger. Whatever you are. You want the room, it's two silver. You want the story, that's free.\""]},{"code":101,"indent":0,"parameters":["People2",4,0,2]},{"code":401,"indent":0,"parameters":["\"Automata been dormant since before I was born. My grandmother used to say they'd start back up again one day — said the old world wasn't as dead as it looked."]},{"code":401,"indent":0,"parameters":["I told her she was superstitious."]},{"code":401,"indent":0,"parameters":["I owe her an apology.\""]},{"code":102,"indent":0,"parameters":[["Rest here (20G)","Just passing through"],-2,0,2,0]},{"code":111,"indent":0,"parameters":[4,0,0]},{"code":102,"indent":0,"parameters":[["Yes","No"],1,0,2,0]},{"code":111,"indent":0,"parameters":[4,0,0]},{"code":125,"indent":0,"parameters":[1,0,20]},{"code":314,"indent":0,"parameters":[0,0]},{"code":101,"indent":0,"parameters":["People2",4,0,2]},{"code":401,"indent":0,"parameters":["\"Room's yours. Sleep well — or don't. The seam's been quiet since the automata woke up, but the quiet is worse somehow.\""]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":