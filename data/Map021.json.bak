    {
      "id": 8,
      "name": "CUTTER-9",
      "note": "",
      "pages": [
        {
          "conditions": {
            "actorId": 1,
            "actorValid": false,
            "itemId": 1,
            "itemValid": false,
            "selfSwitchCh": "A",
            "selfSwitchValid": false,
            "switch1Id": 1,
            "switch1Valid": false,
            "switch2Id": 1,
            "switch2Valid": false,
            "variableId": 1,
            "variableValid": false,
            "variableValue": 0
          },
          "directionFix": false,
          "image": {
            "characterIndex": 0,
            "characterName": "!Other2",
            "direction": 2,
            "pattern": 1,
            "tileId": 0
          },
          "list": [
            {
              "code": 101,
              "indent": 0,
              "parameters": [
                "",
                0,
                0,
                2
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "The automaton stands motionless, its joints locked in an attitude of interrupted work. One arm rises slightly, then drops. Whatever it was in the middle of doing before The Collapse, it remembers it distantly — like a word on the tip of a tongue."
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "It does not attack. It does not acknowledge you. It simply waits."
              ]
            },
            {
              "code": 101,
              "indent": 0,
              "parameters": [
                "",
                0,
                0,
                2
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "Scratched into its iron chassis near the shoulder plate, in letters so worn you almost miss them:"
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "[CUTTER-9]"
              ]
            },
            {
              "code": 0,
              "indent": 0,
              "parameters": []
            }
          ],
