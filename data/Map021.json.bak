          },
          "directionFix": false,
          "image": {
            "characterIndex": 3,
            "characterName": "People1",
            "direction": 2,
            "pattern": 1,
            "tileId": 0
          },
          "list": [
            {
              "code": 101,
              "indent": 0,
              "parameters": [
                "People1",
                3,
                0,
                2
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "Nobody goes in. Foreman's orders. The automata are active in the lower levels — anyone who goes down doesn't come back up."
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "If you need to know more, talk to Briggs at the Hall."
              ]
            },
            {
              "code": 101,
              "indent": 0,
              "parameters": [
                "People1",
                3,
                0,
                2
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "Vera went in three days ago. Haven't heard from her since."
              ]
            },
            {
              "code": 0,
              "indent": 0,
              "parameters": []
