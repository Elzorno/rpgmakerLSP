                "LSP_KaiFace",
                0,
                0,
                2
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "\\N[Vera]: That's not a machine. That's a transmission."
              ]
            },
            {
              "code": 101,
              "indent": 0,
              "parameters": [
                "Elder",
                0,
                0,
                2
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "\\N[Eldon]: The broadcast is generating a standing interference pattern. It's holding itself together through signal coherence. Disrupt the pattern and it collapses."
              ]
            },
            {
              "code": 101,
              "indent": 0,
              "parameters": [
                "",
                0,
                0,
                2
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "The Broadcast Engine turns toward them. From every speaker in the room, a voice -- flat, enormous, without inflection:"
              ]
            },
            {
              "code": 101,
              "indent": 0,
              "parameters": [
                "",
                0,
                0,
                2
              ]
            },
            {
              "code": 401,
              "indent": 0,
              "parameters": [
                "CONNECTION IS LIFE. PROTOCOL DEMANDS COMPLIANCE. STAND DOWN OR BE INDEXED."
              ]
            },
            {
              "code": 301,
              "indent": 0,
              "parameters": [
                0,
                3,
                false,
                false
              ]
            },
            {
              "code": 121,
