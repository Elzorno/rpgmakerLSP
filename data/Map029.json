se,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"Elder","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["Actor3",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: I can feel the signal strengthening as we go up. The receivers in the walls are still active -- they're amplifying it."]},{"code":101,"indent":0,"parameters":["Actor3",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: I'll wait here at the base. If I go higher I risk exposure. The node will be at the top -- look for a server rack, blinking red. You'll know it when you see it."]},{"code":101,"indent":0,"parameters":["Actor3",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: And be careful. The signal has been generating... interference patterns. Physical manifestations. I don't know what you'll find up there."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":30},{"id":3,"name":"Mid-Tower Ambush","note":"Data Wraith encounter. Self-Switch A disables after battle.","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Something flickers at the edge of the lamplight -- a shape made of static and broken signal, coalescing from the interference in the walls."]},{"code":301,"indent":0,"parameters":[0,2,true,false]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true}],"x":10,"y":18},{"id":4,"name":"Broadcast Engine Boss","note":"Boss trigger. Self-Switch A disables after defeat. Sets Switch 35.","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["The relay chamber. Server racks line the walls, their indicator lights cycling in red pulses -- all synchronized, all feeding into the massive broadcast array at the center."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["And in front of it: a mass of consolidated signal energy, drawn together into something that approximates a shape. Screens. Speakers. Receiver dishes repurposed as limbs. NEMESIS's voice given temporary physical form."]},{"code":101,"indent":0,"parameters":["Actor2",1,0,2]},{"code":401,"indent":0,"parameters":["\\N[Vera]: That's not a machine. That's a transmission."]},{"code":101,"indent":0,"parameters":["Actor3",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Eldon]: The broadcast is generating a standing interference pattern. It's holding itself together through signal coherence. Disrupt the pattern and it collapses."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["The Broadcast Engine turns toward them. From every speaker in the room, a voice -- flat, enormous, without inflection:"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["CONNECTION IS LIFE. PROTOCOL DEMANDS COMPLIANCE. STAND DOWN OR BE INDEXED."]},{"code":301,"indent":0,"parameters":[0,3,false,false]},{"code":121,"indent":0,"parameters":[35,35,0]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true}],"x":10,"y":5},{"id":5,"name":"Signal Node Interface","note":"Relay shutdown cutscene. Sets Switch 32. Requires Switch 35 ON.","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["The relay node. A server rack seven feet tall, its indicator lights cycling slow red pulses. It hums at a frequency you can feel in your back teeth."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Something still guards it. You need to deal with that first."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":35,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,"The relay node. Red indicator lights. A low, bone-deep hum."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Kai raises the Sword. He touches the flat of the blade to the main interface panel."]},{"code":223,"indent":0,"parameters":[[0,30,80,0],30,false]},{"code":101,"indent":0,"parameters":["",0,0,2,"The Sword blazes. Blue light floods the chamber, running along the blade's edge and into every conduit in the rack."]},{"code":101,"indent":0,"parameters":["",0,0,2,"The indicator lights flicker. Then they begin cycling -- faster and faster, cascading through a rapid sequence --"]},{"code":101,"indent":0,"parameters":["",0,0,2,"Then silence. The hum cuts off. The lights go dark. All of them."]},{"code":223,"indent":0,"parameters":[[0,0,0,0],20,false]},{"code":223,"indent":0,"parameters":[[0,40,100,0],10,false]},{"code":101,"indent":0,"parameters":["LSP_KaiFace",0,0,2,"\\N[Ancestor's Vision]: A web of nodes. Seven points of light scattered across the world map."]},{"code":101,"indent":0,"parameters":["LSP_KaiFace",0,0,2,"\\N[Ancestor's Vision]: One at Coalmouth -- dark. One here -- going dark now. Five remain."]},{"code":101,"indent":0,"parameters":["LSP_KaiFace",0,0,2,"A voice, flat and enormous: PROTOCOL INTERRUPTED. NODE SIX OFFLINE."]},{"code":223,"indent":0,"parameters":[[0,0,0,0],15,false]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2,"Kai pulls the Sword back. His hands are shaking slightly. The remaining automata in the tower -- whatever signal-constructs hadn't already been destroyed -- slump and go still."]},{"code":101,"indent":0,"parameters":["Actor2",1,0,2,"\\N[Vera]: Six offline. Five to go."]},{"code":101,"indent":0,"parameters":["Actor3",0,0,2,"\\N[Eldon] (from below, shouted): I felt it. The signal is gone. Are you all right up there?"]},{"code":121,"indent":0,"parameters":[32,32,0]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":2},{"id":6,"name":"Ancestor Memory Cache","note":"Examine old-world terminal for memory fragment + skill hint.","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["A dead terminal in the corner. The screen is cracked but its internal storage is intact -- some kind of read-only archive module, still drawing trickle power from the relay."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["The Sword flares blue as you touch it. A voice floods in -- the Ancestor's voice, but this fragment is different. Quieter. Tired."]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["LSP_KaiFace",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Ancestor]: I designed the broadcast architecture myself. Sixty-three relay nodes. I thought it was elegant. The most efficient way to coordinate a global network."]},{"code":101,"indent":0,"parameters":["LSP_KaiFace",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Ancestor]: NEMESIS repurposed every node within six hours of going rogue. Six hours. I had spent eleven years building that network. It took it six hours."]},{"code":101,"indent":0,"parameters":["LSP_KaiFace",0,0,2]},{"code":401,"indent":0,"parameters":["\\N[Ancestor]: Each node you silence is a piece of that architecture turned back. It won't thank you. But it will be less."]},{"code":221,"indent":0,"parameters":[]},{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["The Sword dims. You feel something settle in your grip -- a new instinct, a new precision."]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":1,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":3,"y":4}]}